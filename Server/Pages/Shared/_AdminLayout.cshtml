@using Microsoft.AspNetCore.Http
@inject UserService userService
@inject IAdminMenuService adminMenuService

@{
    var title = ViewData["Title"] ?? "Admin Panel";
    var username = (await userService.GetUserAsync(User)).Username;
    var currentPath = Context.Request.Path.Value?.ToLowerInvariant();

    var menuItems = new List<(string Name, string IconSvg, string Url, bool IsBuiltIn)>();

    menuItems.Add(("Dashboard", @"<svg viewBox=""0 0 24 24""><polyline points=""22 12 18 12 15 21 9 3 6 12 2 12"" /></svg>", "/admin", true));

    foreach (var item in adminMenuService.GetItems().OrderBy(i => i.Order))
    {
        menuItems.Add((item.Name, item.IconSvg, item.Url, false));
    }

    menuItems.Add(("Plugins", @"<svg viewBox=""0 0 24 24""><path d=""M12 2v6m0 8v6M4.93 4.93l4.24 4.24m5.66 5.66l4.24 4.24M2 12h6m8 0h6M4.93 19.07l4.24-4.24m5.66-5.66l4.24-4.24"" /></svg>", "/admin/plugins", true));
    menuItems.Add(("Users", @"<svg viewBox=""0 0 24 24""><path d=""M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"" /><circle cx=""9"" cy=""7"" r=""4"" /><path d=""M23 21v-2a4 4 0 0 0-3-3.87"" /><path d=""M16 3.13a4 4 0 0 1 0 7.75"" /></svg>", "/admin/users", true));
    menuItems.Add(("Settings", @"<svg viewBox=""0 0 24 24""><circle cx=""12"" cy=""12"" r=""3"" /><path d=""M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"" /></svg>", "/admin/settings", true));
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title - SharpPress Admin</title>

    <style>
        :root {
            --accent: #8b5cf6;
            --bg-body: #0f172a;
            --bg-sidebar: #161b22;
            --bg-card: #1e293b;
            --bg-input: #0b1120;
            --bg-hover: #252b36;
            --text-main: #e2e8f0;
            --text-muted: #94a3b8;
            --text-white: #ffffff;
            --primary: #4f46e5;
            --primary-hover: #4338ca;
            --primary-glow: rgba(79, 70, 229, 0.25);
            --success: #10b981;
            --danger: #ef4444;
            --warning: #f59e0b;
            --radius-lg: 16px;
            --radius-md: 12px;
            --radius-sm: 8px;
            --border-subtle: rgba(255, 255, 255, 0.08);
            --shadow-soft: 0 8px 30px rgba(0, 0, 0, 0.25);
            --shadow-glow: 0 0 20px var(--primary-glow);
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            background-color: var(--bg-body);
            color: var(--text-main);
            height: 100vh;
            overflow: hidden;
            -webkit-font-smoothing: antialiased;
        }

        a {
            text-decoration: none;
            color: inherit;
        }

        ul {
            list-style: none;
        }

        #admin-interface {
            display: flex;
            height: 100vh;
            width: 100%;
        }

        .sidebar {
            width: 260px;
            background: var(--bg-sidebar);
            border-right: 1px solid var(--border-subtle);
            display: flex;
            flex-direction: column;
            flex-shrink: 0;
        }

        .sidebar-header {
            padding: 1.5rem;
            text-align: center;
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--text-white);
            border-bottom: 1px solid var(--border-subtle);
        }

        .sidebar-menu {
            padding: 1.5rem 0.75rem;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .menu-item {
            display: flex;
            align-items: center;
            padding: 0.85rem 1.25rem;
            color: var(--text-muted);
            border-radius: var(--radius-md);
            cursor: pointer;
            transition: 0.2s;
        }

            .menu-item:hover {
                background: rgba(255,255,255,0.05);
                color: var(--text-white);
                transform: translateX(4px);
            }

            .menu-item.active {
                background: var(--primary);
                color: var(--text-white);
                box-shadow: var(--shadow-glow);
            }

        .menu-icon {
            margin-right: 12px;
            width: 20px;
            height: 20px;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .menu-icon svg {
                width: 18px;
                height: 18px;
                stroke: currentColor;
                fill: none;
                stroke-width: 1.8;
                stroke-linecap: round;
                stroke-linejoin: round;
            }

        .main-content {
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .top-bar {
            height: 70px;
            background: rgba(255,255,255,0.02);
            border-bottom: 1px solid var(--border-subtle);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 2.5rem;
        }

        .user-profile {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .avatar {
            width: 36px;
            height: 36px;
            background: linear-gradient(135deg, var(--primary), #818cf8);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            color: white;
        }

        .content-scroll {
            flex-grow: 1;
            overflow-y: auto;
            padding: 2.5rem;
        }

        .btn-logout {
            background: rgba(239, 68, 68, 0.1);
            color: var(--danger);
            border: 1px solid rgba(239, 68, 68, 0.2);
            padding: 0.5rem 1rem;
            border-radius: var(--radius-sm);
            font-size: 0.85rem;
            cursor: pointer;
            transition: 0.2s;
            display: flex;
            align-items: center;
            gap: 6px;
        }

            .btn-logout:hover {
                background: rgba(239, 68, 68, 0.2);
            }

            .btn-logout svg {
                width: 15px;
                height: 15px;
                stroke: currentColor;
                fill: none;
                stroke-width: 2;
                stroke-linecap: round;
                stroke-linejoin: round;
            }

        .card {
            background: var(--bg-card);
            border: 1px solid var(--border-subtle);
            border-radius: var(--radius-lg);
            padding: 1.5rem;
            margin-bottom: 1.5rem;
        }

            .card:hover {
                transform: translateY(-2px);
                box-shadow: 0 12px 40px rgba(0, 0, 0, 0.2);
            }

        .card-header {
            margin-bottom: 1.5rem;
            padding-bottom: 1rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--border-subtle);
        }

        .card-title {
            font-size: 1.4rem;
            font-weight: 600;
            color: var(--text-white);
            letter-spacing: -0.3px;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2.5rem;
        }

        .stat-box {
            background: linear-gradient(135deg, var(--bg-card), rgba(255,255,255,0.03));
            padding: 2rem;
            border-radius: var(--radius-lg);
            border: 1px solid var(--border-subtle);
            text-align: center;
            transition: transform 0.3s ease;
        }

            .stat-box:hover {
                transform: translateY(-3px);
            }

        .stat-value {
            font-size: 1rem;
            font-weight: 700;
            color: var(--text-white);
            margin-top: 0.5rem;
            letter-spacing: -1px;
        }

        .stat-label {
            font-size: 0.85rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 1.2px;
            font-weight: 600;
        }

        .table-container {
            overflow-x: auto;
            border: 1px solid var(--border-subtle);
            border-radius: var(--radius-md);
        }

        table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
        }

        th {
            background-color: rgba(255,255,255,0.02);
            color: var(--text-muted);
            font-weight: 600;
            text-align: left;
            padding: 1rem 1.25rem;
            border-bottom: 1px solid var(--border-subtle);
        }

        td {
            padding: 1rem 1.25rem;
            border-bottom: 1px solid var(--border-subtle);
            color: var(--text-main);
            transition: background 0.2s;
        }

        tr:hover td {
            background-color: rgba(255,255,255,0.02);
        }

        .badge {
            display: inline-block;
            padding: 0.4rem 0.75rem;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 700;
            color: white;
            letter-spacing: 0.5px;
        }

        .badge-primary {
            background-color: var(--primary);
            box-shadow: 0 0 10px var(--primary-glow);
        }

        .badge-success {
            background-color: var(--success);
        }

        .badge-danger {
            background-color: var(--danger);
        }

        .alert {
            padding: 1rem 1.25rem;
            border-radius: var(--radius-md);
            border: 1px solid var(--border-subtle);
            background-color: rgba(59, 130, 246, 0.05);
            margin-bottom: 1rem;
            color: var(--text-main);
        }

        .alert-info {
            border-left: 4px solid var(--primary);
        }

        .alert-danger {
            border-left: 4px solid var(--danger);
        }

        .logo {
            color: white;
        }

            .logo span {
                color: var(--accent);
            }
    </style>
</head>
<body>
    <div id="admin-interface">
        <aside class="sidebar">
            <div class="sidebar-header">
                <div class="logo">Sharp<span>Press</span></div>
            </div>
            <ul class="sidebar-menu">
                @foreach (var item in menuItems)
                {
                    var isActive = currentPath == item.Url.ToLowerInvariant() ? "active" : "";
                    <li>
                        <a href="@item.Url" class="menu-item @isActive">
                            <span class="menu-icon">@Html.Raw(item.IconSvg)</span>
                            @item.Name
                        </a>
                    </li>
                }

                <li style="margin-top: auto;">
                    <a href="/" class="menu-item" style="color: var(--text-muted);">
                        <span class="menu-icon">
                            <svg viewBox="0 0 24 24"><line x1="19" y1="12" x2="5" y2="12" /><polyline points="12 19 5 12 12 5" /></svg>
                        </span>
                        Back to Site
                    </a>
                </li>
            </ul>
        </aside>

        <main class="main-content">
            <header class="top-bar">
                <span style="font-weight: 600; font-size: 1.1rem;">@ViewData["Title"]</span>

                <div style="display: flex; align-items: center; gap: 15px;">
                    <a href="/logout">
                        <button id="logout-btn" class="btn-logout">
                            <svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>
                            Logout
                        </button>
                    </a>

                    <div class="user-profile">
                        <div style="display: flex; flex-direction: column; align-items: flex-end;">
                            <span id="user-name" style="font-size: 0.9rem; font-weight: 600;">@username</span>
                            <span style="font-size: 0.75rem; color: var(--text-muted);">Online</span>
                        </div>
                        <div class="avatar" id="user-avatar">@username[0].ToString().ToUpper()</div>
                    </div>
                </div>
            </header>

            <div class="content-scroll">
                @RenderBody()
            </div>
        </main>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>